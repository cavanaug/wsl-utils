#!/bin/bash
#  ┌──────────────────────────────────────────────────────────────────────────────┐
#  │                                                                              │
#  │    ██╗    ██╗██╗███╗   ██╗      ██████╗  █████╗ ███████╗████████╗███████╗    │
#  │    ██║    ██║██║████╗  ██║      ██╔══██╗██╔══██╗██╔════╝╚══██╔══╝██╔════╝    │
#  │    ██║ █╗ ██║██║██╔██╗ ██║█████╗██████╔╝███████║███████╗   ██║   █████╗      │
#  │    ██║███╗██║██║██║╚██╗██║╚════╝██╔═══╝ ██╔══██║╚════██║   ██║   ██╔══╝      │
#  │    ╚███╔███╔╝██║██║ ╚████║      ██║     ██║  ██║███████║   ██║   ███████╗    │
#  │     ╚══╝╚══╝ ╚═╝╚═╝  ╚═══╝      ╚═╝     ╚═╝  ╚═╝╚══════╝   ╚═╝   ╚══════╝    │
#  │                                                                              │
#  └──────────────────────────────────────────────────────────────────────────────┘
#  win-paste
#  - This script is used to paste the contents of the Windows clipboard into the current WSL terminal STDOUT
#  - It is best used to symlink wl-paste to this script (and place earlier in PATH) to allow for easy compatibility with tools expecting wl-paste
#  - By default this tool strips trailing ^M (CR) characters from text for Unix line endings.
#  - Use --raw to skip line-ending manipulation (binary / exact clipboard bytes).
#  - Use --file-url / --file-path / --file-atpath to materialize clipboard content to a cache file.
#  - wslutil checkhealth will tell you if you need this script or not
#
# Note: It is really a shame that wl-paste doesnt have an option for --strip-cr or similar to strip the ^M characters on its own. This is why this script is still needed for win11/wslg
#
set -euo pipefail

# Check for help option
if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
    cat <<'EOF'
win-paste - Paste from Windows clipboard to stdout

USAGE:
    win-paste [OPTIONS]

DESCRIPTION:
    Retrieves content from the Windows clipboard and outputs it to stdout.
    By default strips trailing carriage return characters (^M) for Unix line endings.

    If WSLg is available and enabled, uses wl-paste with proper fallback.
    Otherwise, uses PowerShell's Get-Clipboard command.

    File materialize modes write clipboard content under
    ${XDG_CACHE_HOME:-$HOME/.cache}/wslutil/clipboard and emit a path/URL;
    with no --format, the richest available clipboard format is chosen.

OPTIONS:
    -h, --help      Show this help message and exit
    --raw           Do not alter line endings (no ^M stripping)
    --file-url      Materialize clipboard to cache; print file:// URL
    --file-path     Materialize clipboard to cache; print absolute path
    --file-atpath   Materialize clipboard to cache; print @<absolute-path>
    --format FMT    Convert/write as png|jpeg|jpg|gif|webp|txt|html

    When WSLg is available, all wl-paste options are supported:
    -n, --no-newline    Don't add newline at end of output (DEFAULT)
    -l, --list-types    List available MIME types
    -t, --type TYPE     Select MIME type to paste
    -p, --primary       Use primary selection (if available)
    -s, --seat SEAT     Use specific seat

EXAMPLES:
    win-paste > clipboard.txt       # Save clipboard to file
    win-paste | grep "error"        # Search clipboard content
    win-paste --raw > binary.bin    # Exact clipboard bytes
    echo "backup: $(win-paste)"     # Include clipboard in output
    win-paste --file-atpath         # Materialize; print @/path
    win-paste --file-url --format png  # Materialize as PNG; print file:// URL

NOTES:
    - Logs usage to ~/.local/state/wslutil/win-clipboard.log
    - Automatically handles Windows line endings unless --raw is used
    - Can be symlinked as wl-paste for compatibility
EOF
    exit 0
fi

_wsu_bin="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [[ -f "$_wsu_bin/../lib/wslutil-clipboard-file.sh" ]]; then
    # shellcheck source=/dev/null
    source "$_wsu_bin/../lib/wslutil-clipboard-file.sh"
elif [[ -f "$_wsu_bin/../share/wslutil/lib/wslutil-clipboard-file.sh" ]]; then
    # shellcheck source=/dev/null
    source "$_wsu_bin/../share/wslutil/lib/wslutil-clipboard-file.sh"
else
    echo "win-paste: clipboard helper not found" >&2
    exit 1
fi

WIN_WINDIR=${WIN_WINDIR:-/mnt/c/Windows}
# Overridable for tests; production default is the WSLg binary.
WL_PASTE=${WL_PASTE:-/usr/bin/wl-paste}

RAW=0
FILE_MODE="" # url|path|atpath|empty
FORMAT=""    # optional short name
ARGS=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        --raw)
            RAW=1
            shift
            ;;
        --file-url | --file-path | --file-atpath)
            if [[ -n "$FILE_MODE" ]]; then
                echo "win-paste: use only one of --file-url, --file-path, --file-atpath" >&2
                exit 1
            fi
            case "$1" in
                --file-url) FILE_MODE=url ;;
                --file-path) FILE_MODE=path ;;
                --file-atpath) FILE_MODE=atpath ;;
            esac
            shift
            ;;
        --format)
            [[ $# -ge 2 ]] || {
                echo "win-paste: --format requires a value" >&2
                exit 1
            }
            FORMAT="$2"
            shift 2
            ;;
        --format=*)
            FORMAT="${1#--format=}"
            shift
            ;;
        -h | --help)
            shift
            ;;
        *)
            ARGS+=("$1")
            shift
            ;;
    esac
done

if [[ -n "$FILE_MODE" && $RAW -eq 1 ]]; then
    echo "win-paste: --raw cannot be combined with --file-*" >&2
    exit 1
fi

if [[ -n "$FORMAT" ]]; then
    wslutil_clipboard_format_ext "$FORMAT" >/dev/null || {
        echo "win-paste: unsupported --format: $FORMAT" >&2
        exit 1
    }
fi

powershell_bin() {
    printf '%s' "${WIN_WINDIR}/System32/WindowsPowerShell/v1.0/powershell.exe"
}

# Returns 0 and writes bytes to $1 when clipboard has plain text
ps_try_text() {
    local out="$1"
    "$(powershell_bin)" -NoProfile -Command \
        '[Console]::OutputEncoding=[System.Text.Encoding]::UTF8; $t=Get-Clipboard -Raw -ErrorAction SilentlyContinue; if($null -eq $t -or $t -eq ""){ exit 1 }; [Console]::Out.Write($t)' \
        >"$out" 2>/dev/null
}

# Returns 0 and writes HTML to $1 when available
ps_try_html() {
    local out="$1"
    "$(powershell_bin)" -NoProfile -Command \
        '$h=Get-Clipboard -TextFormatType Html -ErrorAction SilentlyContinue; if($null -eq $h -or $h -eq ""){ exit 1 }; [Console]::OutputEncoding=[System.Text.Encoding]::UTF8; [Console]::Out.Write($h)' \
        >"$out" 2>/dev/null
}

# Returns 0 and writes PNG bytes to $1 when clipboard has an image
ps_try_image_png() {
    local out="$1" win_out
    if command -v wslpath >/dev/null 2>&1; then
        win_out="$(wslpath -w "$out")"
    else
        win_out="$out"
    fi
    WIN_PASTE_OUT="$win_out" "$(powershell_bin)" -NoProfile -Command \
        'Add-Type -AssemblyName System.Windows.Forms; Add-Type -AssemblyName System.Drawing; $img=[Windows.Forms.Clipboard]::GetImage(); if($null -eq $img){exit 1}; $img.Save($env:WIN_PASTE_OUT,[Drawing.Imaging.ImageFormat]::Png)' \
        2>/dev/null
    [[ -s "$out" ]]
}

wl_list_types() {
    "$WL_PASTE" -l 2>/dev/null || true
}

wl_try_mime() {
    local mime="$1" out="$2"
    "$WL_PASTE" -n -t "$mime" >"$out" 2>/dev/null && [[ -s "$out" ]]
}

# Convert BMP bytes file → PNG file. Uses magick/convert/ffmpeg when available.
wl_bmp_to_png() {
    local src="${1:?}" dest="${2:?}"
    if command -v magick >/dev/null 2>&1; then
        magick "$src" "png:$dest" 2>/dev/null && [[ -s "$dest" ]] && return 0
    fi
    if command -v convert >/dev/null 2>&1; then
        # Dest is often an extensionless mktemp path — force PNG codec
        convert "$src" "png:$dest" 2>/dev/null && [[ -s "$dest" ]] && return 0
    fi
    if command -v ffmpeg >/dev/null 2>&1; then
        ffmpeg -y -loglevel error -i "$src" -f image2 -c:v png "$dest" 2>/dev/null && [[ -s "$dest" ]] && return 0
    fi
    return 1
}

# Try image MIME ladder (png → jpeg → gif → webp → bmp→png). Sets KIND/EXT; writes to $2.
wl_try_richest_image() {
    local types="$1" out="$2" mime bmp_tmp
    for mime in image/png image/jpeg image/gif image/webp; do
        if printf '%s\n' "$types" | grep -qx "$mime" && wl_try_mime "$mime" "$out"; then
            KIND=image
            case "$mime" in
                image/png) EXT=png ;;
                image/jpeg) EXT=jpg ;;
                image/gif) EXT=gif ;;
                image/webp) EXT=webp ;;
            esac
            return 0
        fi
    done
    # Windows / Snipping Tool often offers only image/bmp via WSLg
    for mime in image/bmp image/x-ms-bmp; do
        if printf '%s\n' "$types" | grep -qx "$mime"; then
            bmp_tmp="$(mktemp)"
            if wl_try_mime "$mime" "$bmp_tmp" && wl_bmp_to_png "$bmp_tmp" "$out"; then
                rm -f "$bmp_tmp"
                KIND=image
                EXT=png
                return 0
            fi
            rm -f "$bmp_tmp"
            # Convert unavailable or failed: PowerShell GetImage → PNG
            if ps_try_image_png "$out"; then
                KIND=image
                EXT=png
                return 0
            fi
        fi
    done
    # Any other image/* we didn't handle: last-resort PS GetImage
    if printf '%s\n' "$types" | grep -q '^image/'; then
        if ps_try_image_png "$out"; then
            KIND=image
            EXT=png
            return 0
        fi
    fi
    return 1
}

# WSLg richest ladder: image → text/html → text/plain (aligned with PS)
wl_fetch_clipboard_payload() {
    local format="${1:-}" tmp types bmp_tmp
    tmp="$(mktemp)"
    types="$(wl_list_types)"

    if [[ -n "$format" ]]; then
        case "$format" in
            txt)
                wl_try_mime text/plain "$tmp" || {
                    rm -f "$tmp"
                    echo "win-paste: no text on clipboard" >&2
                    return 1
                }
                sed 's/\r$//' "$tmp" >"${tmp}.out" && mv "${tmp}.out" "$tmp"
                PAYLOAD_FILE="$tmp"
                KIND=text
                EXT=txt
                return 0
                ;;
            html)
                wl_try_mime text/html "$tmp" || {
                    rm -f "$tmp"
                    echo "win-paste: no HTML on clipboard" >&2
                    return 1
                }
                PAYLOAD_FILE="$tmp"
                KIND=html
                EXT=html
                return 0
                ;;
            png)
                if printf '%s\n' "$types" | grep -qx 'image/png' && wl_try_mime image/png "$tmp"; then
                    PAYLOAD_FILE="$tmp"
                    KIND=image
                    EXT=png
                    return 0
                fi
                # BMP-only clipboards (common on Windows) → PNG
                for mime in image/bmp image/x-ms-bmp; do
                    if printf '%s\n' "$types" | grep -qx "$mime"; then
                        bmp_tmp="$(mktemp)"
                        if wl_try_mime "$mime" "$bmp_tmp" && wl_bmp_to_png "$bmp_tmp" "$tmp"; then
                            rm -f "$bmp_tmp"
                            PAYLOAD_FILE="$tmp"
                            KIND=image
                            EXT=png
                            return 0
                        fi
                        rm -f "$bmp_tmp"
                    fi
                done
                if ps_try_image_png "$tmp"; then
                    PAYLOAD_FILE="$tmp"
                    KIND=image
                    EXT=png
                    return 0
                fi
                rm -f "$tmp"
                echo "win-paste: no image on clipboard" >&2
                return 1
                ;;
            jpeg | jpg | gif | webp)
                rm -f "$tmp"
                echo "win-paste: --format $format not supported yet (use png)" >&2
                return 1
                ;;
            *)
                rm -f "$tmp"
                return 1
                ;;
        esac
    fi

    if wl_try_richest_image "$types" "$tmp"; then
        PAYLOAD_FILE="$tmp"
        return 0
    fi
    if printf '%s\n' "$types" | grep -qx 'text/html' && wl_try_mime text/html "$tmp"; then
        PAYLOAD_FILE="$tmp"
        KIND=html
        EXT=html
        return 0
    fi
    if wl_try_mime text/plain "$tmp"; then
        sed 's/\r$//' "$tmp" >"${tmp}.out" && mv "${tmp}.out" "$tmp"
        PAYLOAD_FILE="$tmp"
        KIND=text
        EXT=txt
        return 0
    fi
    rm -f "$tmp"
    echo "win-paste: clipboard empty or unsupported" >&2
    return 1
}

# Sets globals PAYLOAD_FILE KIND EXT via temp file. format is optional.
ps_fetch_clipboard_payload() {
    local format="${1:-}" tmp
    tmp="$(mktemp)"
    if [[ -n "$format" ]]; then
        case "$format" in
            txt)
                ps_try_text "$tmp" || {
                    rm -f "$tmp"
                    echo "win-paste: no text on clipboard" >&2
                    return 1
                }
                # strip CR for stored text (materialize owns encoding; not --raw)
                sed 's/\r$//' "$tmp" >"${tmp}.out" && mv "${tmp}.out" "$tmp"
                PAYLOAD_FILE="$tmp"
                KIND=text
                EXT=txt
                return 0
                ;;
            html)
                ps_try_html "$tmp" || {
                    rm -f "$tmp"
                    echo "win-paste: no HTML on clipboard" >&2
                    return 1
                }
                PAYLOAD_FILE="$tmp"
                KIND=html
                EXT=html
                return 0
                ;;
            png)
                ps_try_image_png "$tmp" || {
                    rm -f "$tmp"
                    echo "win-paste: no image on clipboard" >&2
                    return 1
                }
                PAYLOAD_FILE="$tmp"
                KIND=image
                EXT=png
                return 0
                ;;
            jpeg | jpg | gif | webp)
                rm -f "$tmp"
                echo "win-paste: --format $format not supported yet (use png)" >&2
                return 1
                ;;
            *)
                rm -f "$tmp"
                return 1
                ;;
        esac
    fi

    # richest: image → html → text
    if ps_try_image_png "$tmp"; then
        PAYLOAD_FILE="$tmp"
        KIND=image
        EXT=png
        return 0
    fi
    if ps_try_html "$tmp"; then
        PAYLOAD_FILE="$tmp"
        KIND=html
        EXT=html
        return 0
    fi
    if ps_try_text "$tmp"; then
        sed 's/\r$//' "$tmp" >"${tmp}.out" && mv "${tmp}.out" "$tmp"
        PAYLOAD_FILE="$tmp"
        KIND=text
        EXT=txt
        return 0
    fi
    rm -f "$tmp"
    echo "win-paste: clipboard empty or unsupported" >&2
    return 1
}

fetch_clipboard_payload() {
    local format="${1:-}"
    if [[ ${WSL2_GUI_APPS_ENABLED:-} == "1" && -x "$WL_PASTE" ]]; then
        wl_fetch_clipboard_payload "$format"
    else
        ps_fetch_clipboard_payload "$format"
    fi
}

materialize_clipboard_and_emit() {
    local mode="$1" format="${2:-}" path store_status=0
    fetch_clipboard_payload "$format" || return 1
    path="$(wslutil_clipboard_store "$PAYLOAD_FILE" "$KIND" "$EXT")" || store_status=$?
    rm -f "$PAYLOAD_FILE"
    [[ $store_status -eq 0 ]] || return "$store_status"
    wslutil_clipboard_emit "$mode" "$path"
    printf '\n'
}

if [[ -n "$FILE_MODE" ]]; then
    materialize_clipboard_and_emit "$FILE_MODE" "$FORMAT"
    exit $?
fi

paste_clipboard() {
    if [[ ${WSL2_GUI_APPS_ENABLED:-} == "1" && -x "$WL_PASTE" ]]; then
        if [[ -n "${WSLUTIL_DEBUG:-}" ]]; then
            mkdir -p ${HOME}/.local/state/wslutil
            echo "$(date --rfc-3339=s) - $WL_PASTE [$(basename -- $(ps -p $PPID -o cmd= | cut -f1 -d' '))] $(basename ${0}) ${*}" >>${HOME}/.local/state/wslutil/win-clipboard.log
        fi
        "$WL_PASTE" -n "$@"
    else
        if [[ -n "${WSLUTIL_DEBUG:-}" ]]; then
            mkdir -p ${HOME}/.local/state/wslutil
            echo "$(date --rfc-3339=s) - win-paste script [$(basename -- $(ps -p $PPID -o cmd= | cut -f1 -d' '))] $(basename ${0}) ${*}" >>${HOME}/.local/state/wslutil/win-clipboard.log
        fi
        "$(powershell_bin)" -NoProfile -Command '[Console]::OutputEncoding = [System.Text.Encoding]::UTF8; $OutputEncoding = [System.Text.Encoding]::UTF8; [Console]::Out.Write((Get-Clipboard -Raw).ToString())'
    fi
}

if [[ $RAW -eq 1 ]]; then
    paste_clipboard "${ARGS[@]}"
else
    # Strip trailing CR (CRLF -> LF). Use --raw for binary / exact bytes.
    paste_clipboard "${ARGS[@]}" | sed 's/\r$//'
fi
