#!/bin/bash
#  в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ
#  в”Ӯ                                                                       в”Ӯ
#  в”Ӯ    в–Ҳв–Ҳв•—    в–Ҳв–Ҳв•—в–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв•—   в–Ҳв–Ҳв•—       в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв•—   в–Ҳв–Ҳв•—    в”Ӯ
#  в”Ӯ    в–Ҳв–Ҳв•‘    в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв•‘      в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв–Ҳв–Ҳв•”в•җв•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в•ҡв–Ҳв–Ҳв•— в–Ҳв–Ҳв•”в•қ    в”Ӯ
#  в”Ӯ    в–Ҳв–Ҳв•‘ в–Ҳв•— в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в–Ҳв–Ҳв•— в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қ в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қ     в”Ӯ
#  в”Ӯ    в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘в•ҡв•җв•җв•җв•җв•қв–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв•җв•қ   в•ҡв–Ҳв–Ҳв•”в•қ      в”Ӯ
#  в”Ӯ    в•ҡв–Ҳв–Ҳв–Ҳв•”в–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘ в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв•‘      в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘        в–Ҳв–Ҳв•‘       в”Ӯ
#  в”Ӯ     в•ҡв•җв•җв•қв•ҡв•җв•җв•қ в•ҡв•җв•қв•ҡв•җв•қ  в•ҡв•җв•җв•җв•қ       в•ҡв•җв•җв•җв•җв•җв•қ в•ҡв•җв•җв•җв•җв•җв•қ в•ҡв•җв•қ        в•ҡв•җв•қ       в”Ӯ
#  в”Ӯ                                                                       в”Ӯ
#  в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ
#  win-copy
#  - This tool is ONLY NEEDED if you are not able to utilize wslg (old win10 etc)
#  - eval $(wslutil init) should configure the wslg properly that this should not be needed
#
#  - This script is used to copy the WSL stdin to the Windows clipboard
#  - It is best used to symlink wl-copy to this script (and place earlier in PATH) to allow for easy compatibility with tools expecting wl-paste
#  - wslutil checkhealth will tell you if you need this script or not
#
set -euo pipefail

WIN_WINDIR=${WIN_WINDIR:-/mnt/c/Windows}

is_wsl() {
    [[ -n "${WSL_DISTRO_NAME:-}" || -n "${WSL_INTEROP:-}" ]] && return 0
    grep -qi microsoft /proc/sys/kernel/osrelease 2>/dev/null
}

debug_log() {
    local backend="$1"
    local parent_cmd

    if [[ -z "${WSLUTIL_DEBUG:-}" ]]; then
        return 0
    fi

    mkdir -p "${HOME}/.local/state/wslutil"
    parent_cmd="$(ps -p "${PPID}" -o cmd= 2>/dev/null | cut -f1 -d' ' || true)"
    echo "$(date --rfc-3339=s) - ${backend} [$(basename -- "${parent_cmd}")] $(basename -- "${0}") ${*}" >>"${HOME}/.local/state/wslutil/win-clipboard.log"
}

emit_osc52() {
    local input_file="$1"
    local payload sequence

    payload="$(base64 <"${input_file}" | tr -d '\r\n')"
    sequence="$(printf '\033]52;c;%s\a' "${payload}")"

    if [[ -n "${SSH_TTY:-}" && -w "${SSH_TTY}" ]]; then
        printf '%s' "${sequence}" >"${SSH_TTY}"
    elif [[ -w /dev/tty ]]; then
        printf '%s' "${sequence}" >/dev/tty
    else
        printf '%s' "${sequence}"
    fi
}

# Check for help option
if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
    cat << 'EOF'
win-copy - Copy from stdin to Windows clipboard

USAGE:
    win-copy [OPTIONS]

DESCRIPTION:
    Reads content from stdin and copies it to the best available clipboard backend.
    Works in WSL and non-WSL environments.

    Backend order:
    - WSL + WSLg: /usr/bin/wl-copy
    - WSL fallback: Windows clip.exe
    - Non-WSL + SSH: OSC52 escape sequence to terminal
    - Non-WSL local: wl-copy, xclip, xsel, pbcopy

OPTIONS:
    -h, --help    Show this help message and exit

    When WSLg is available, all wl-copy options are supported:
    -o, --trim-newline    Trim final newline character
    -n, --foreground      Stay in foreground (don't fork)
    -c, --clear          Clear clipboard instead of copying
    -p, --primary        Use primary selection (if available)
    -s, --seat SEAT      Use specific seat

EXAMPLES:
    echo "Hello World" | win-copy     # Copy text to clipboard
    cat file.txt | win-copy           # Copy file contents
    ls -la | win-copy                 # Copy command output

NOTES:
    - Logs usage to ~/.local/state/wslutil/win-clipboard.log
    - Uses OSC52 over SSH when no WSL clipboard backend exists
    - Can be symlinked as wl-copy for compatibility
    - Only needed on older Windows 10 systems without WSLg
EOF
    exit 0
fi

input_file="$(mktemp)"
trap 'rm -f "${input_file}"' EXIT
cat >"${input_file}"

if is_wsl; then
    if [[ ${WSL2_GUI_APPS_ENABLED:-} == "1" && -x /usr/bin/wl-copy ]]; then
        debug_log "/usr/bin/wl-copy (wslg)"
        /usr/bin/wl-copy "$@" <"${input_file}"
        exit $?
    fi

    if [[ -x "${WIN_WINDIR}/System32/clip.exe" ]]; then
        debug_log "${WIN_WINDIR}/System32/clip.exe"
        "${WIN_WINDIR}/System32/clip.exe" "$@" <"${input_file}"
        exit $?
    fi
fi

if [[ -z "${WSL_DISTRO_NAME:-}" && -z "${WSL_INTEROP:-}" && ( -n "${SSH_TTY:-}" || -n "${SSH_CONNECTION:-}" ) ]]; then
    debug_log "osc52"
    emit_osc52 "${input_file}"
    exit $?
fi

if command -v wl-copy >/dev/null 2>&1; then
    debug_log "wl-copy"
    wl-copy "$@" <"${input_file}"
    exit $?
fi

if command -v xclip >/dev/null 2>&1; then
    debug_log "xclip"
    xclip -selection clipboard <"${input_file}"
    exit $?
fi

if command -v xsel >/dev/null 2>&1; then
    debug_log "xsel"
    xsel --clipboard --input <"${input_file}"
    exit $?
fi

if command -v pbcopy >/dev/null 2>&1; then
    debug_log "pbcopy"
    pbcopy <"${input_file}"
    exit $?
fi

echo "win-copy: no clipboard backend found (tried WSL clip.exe, wl-copy, xclip, xsel, pbcopy, and SSH OSC52)" >&2
exit 1
